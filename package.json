{
  "name": "polygon-intersection",
  "author": {
    "name": "Varjak"
  },
  "description": "A library for finding the intersection of two polygons",
  "homepage": "https://github.com/varjak/polygon-intersection-helper",
  "license": "MIT",
  "private": false,
  "version": "0.0.0-development",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/main.umd.cjs",
  "module": "./dist/main.js",
  "typings": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "require": "./dist/main.umd.cjs"
    }
  },
  "scripts": {
    "build": "tsc && vite build",
    "dev": "tsc && vite build --watch",
    "test": "vitest",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "prepare": "npm run build",
    "commit": "git-cz",
    "semantic-release": "semantic-release --branches main"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^v24.12.2",
    "conventional-changelog-conventionalcommits": "^7.0.2",
    "cz-conventional-changelog": "^3.3.0",
    "@semantic-release/github": "^10.0.3",
    "@semantic-release/npm": "^13.1.5",
    "semantic-release": "^25.0.2",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varjak/polygon-intersection-helper.git"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
